<div>
  <p class="rec-status">
    Session: <b>{{status}}</b>
    {{#if uploadLine}}<br />{{uploadLine}}{{/if}}
    {{#if recordingError}}<br /><span class="rec-danger">{{recordingError}}</span>{{/if}}
  </p>

  {{#if isGM}}
    {{#unless hasSession}}
      <div class="rec-row"><button type="button" data-recvtt="create"><i class="fas fa-plus"></i> Create session</button></div>
    {{/unless}}
    {{#if hasSession}}
      <div class="rec-row"><button type="button" data-recvtt="close" class="rec-danger"><i class="fas fa-power-off"></i> End session for everyone</button></div>
    {{/if}}
  {{/if}}

  {{#if hasSession}}
    {{#unless joined}}
      <div class="rec-row"><button type="button" data-recvtt="join"><i class="fas fa-video"></i> Join with webcam</button></div>
    {{/unless}}
    {{#if joined}}
      <div class="rec-row"><button type="button" data-recvtt="devices"><i class="fas fa-gear"></i> Change camera / microphone</button></div>
      <div class="rec-row"><button type="button" data-recvtt="leave"><i class="fas fa-right-from-bracket"></i> Leave session (stop my streaming)</button></div>
    {{/if}}
  {{/if}}

  {{#if participants.length}}
    <ul class="rec-participants">
      {{#each participants}}
        <li><span>{{name}}{{#if liveOnly}} <span class="rec-liveonly-tag">live only</span>{{/if}}</span><span>{{uploaded}}</span></li>
      {{/each}}
    </ul>
  {{/if}}

  {{#if isGM}}
    <p class="rec-status">Recording is controlled from the toolbar (circle icon). Downloads live in the sessions browser (film icon).</p>
  {{/if}}
</div>
